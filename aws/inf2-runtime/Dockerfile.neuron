ARG NEURON_BASE_IMAGE=public.ecr.aws/neuron/pytorch-inference-neuronx:latest
FROM ${NEURON_BASE_IMAGE}

ENV DEBIAN_FRONTEND=noninteractive
WORKDIR /opt/emberlane/inf2-runtime

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash ca-certificates curl git jq python3 python3-pip nginx \
  && rm -rf /var/lib/apt/lists/*

# vLLM Neuron builds can be slow and version-sensitive. For production, prefer a
# baked image/AMI after validating the exact Neuron SDK, PyTorch, transformers,
# and vLLM versions for your model profile.
ARG VLLM_REF=main
RUN python3 -m pip install --upgrade pip wheel setuptools \
  && python3 -m pip install "huggingface_hub[cli]" \
  && git clone --depth 1 --branch "${VLLM_REF}" https://github.com/vllm-project/vllm.git /tmp/vllm \
  && cd /tmp/vllm \
  && if [ -f requirements-neuron.txt ]; then python3 -m pip install -r requirements-neuron.txt; fi \
  && VLLM_TARGET_DEVICE=neuron python3 -m pip install -e . \
  && rm -rf /tmp/vllm

COPY models.yaml ./models.yaml
COPY start-server.sh ./start-server.sh
COPY healthcheck.sh ./healthcheck.sh
COPY scripts ./scripts
COPY server ./server
COPY nginx/nginx.conf /etc/nginx/nginx.conf

RUN chmod +x ./start-server.sh ./healthcheck.sh ./scripts/*.sh ./scripts/render-env.py

EXPOSE 8000 8080
HEALTHCHECK --interval=30s --timeout=5s --retries=3 CMD ./healthcheck.sh

CMD ["./start-server.sh"]
