#!/usr/bin/env bash
set -euo pipefail

# 1. Logging and basic setup
mkdir -p /etc/emberlane /opt/emberlane /opt/emberlane/model-cache /opt/emberlane/neuron-cache /var/log/emberlane
exec > >(tee -a /var/log/emberlane/bootstrap.log) 2>&1

echo "[emberlane] ========================================"
echo "[emberlane] Bootstrap started at $(date -u +%Y-%m-%dT%H:%M:%SZ)"

# 2. OS Detection and Lightweight Package Install
if [[ -f /etc/os-release ]]; then
    . /etc/os-release
    OS_ID=$ID
else
    OS_ID="unknown"
fi

echo "[emberlane] OS detected: $OS_ID ($${VERSION_ID:-unknown})"

case "$OS_ID" in
    ubuntu)
        PM="apt-get"
        export DEBIAN_FRONTEND=noninteractive
        apt-get update -y
        deps=(curl jq unzip snapd python3-pip)
        if ! command -v docker >/dev/null 2>&1; then
            deps+=(docker.io)
        fi
        apt-get install -y "$${deps[@]}" || true # Don't fail if some deps (like docker) are held/pre-installed
        systemctl enable --now docker
        ;;
    amzn|al2023)
        PM="dnf"
        deps=(curl jq unzip python3-pip)
        if ! command -v docker >/dev/null 2>&1; then
            deps+=(docker)
        fi
        dnf install -y "$${deps[@]}" 
        systemctl enable --now docker
        ;;
    *)
        echo "[emberlane] WARNING: Unsupported OS $OS_ID. Attempting to proceed with basic tools."
        ;;
esac

ensure_ssm_agent() {
    case "$OS_ID" in
        ubuntu)
            if ! snap list amazon-ssm-agent >/dev/null 2>&1; then
                echo "[emberlane] installing SSM agent via snap"
                snap install amazon-ssm-agent --classic || true
            fi
            systemctl enable --now snap.amazon-ssm-agent.amazon-ssm-agent.service >/dev/null 2>&1 || true
            snap start amazon-ssm-agent >/dev/null 2>&1 || true
            ;;
        amzn|al2023)
            if ! rpm -q amazon-ssm-agent >/dev/null 2>&1; then
                echo "[emberlane] installing SSM agent via rpm"
                dnf install -y https://s3.amazonaws.com/ec2-downloads-windows/SSMAgent/latest/linux_amd64/amazon-ssm-agent.rpm \
                  || yum install -y https://s3.amazonaws.com/ec2-downloads-windows/SSMAgent/latest/linux_amd64/amazon-ssm-agent.rpm \
                  || true
            fi
            systemctl enable --now amazon-ssm-agent >/dev/null 2>&1 || true
            ;;
    esac
}

ensure_ssm_agent

# 3. Preflight Diagnostic Block
echo "[emberlane] --- PREFLIGHT LOGS ---"
echo "AMI_ID: $(curl -s http://169.254.169.254/latest/meta-data/ami-id)"
echo "INSTANCE_TYPE: $(curl -s http://169.254.169.254/latest/meta-data/instance-type)"
echo "UNAME: $(uname -a)"
echo "OS_RELEASE: $(cat /etc/os-release | grep PRETTY_NAME)"
docker --version || echo "docker not found"

if [[ "${accelerator}" == "cuda" ]]; then
    nvidia-smi || { echo "ERROR: nvidia-smi failed on CUDA instance"; exit 1; }
elif [[ "${accelerator}" == "inf2" ]]; then
    if command -v neuron-ls >/dev/null 2>&1; then
        neuron-ls
    else
        echo "ERROR: neuron-ls not found on Inf2 instance"
        exit 1
    fi
fi
echo "[emberlane] --- PREFLIGHT COMPLETE ---"

# 4. Environment and Secrets
echo "[emberlane] writing runtime environment"
cat >/etc/emberlane/inf2.env <<'ENV'
MODEL_PROFILE=${model_profile}
MODEL_ID=${model_id}
MAX_MODEL_LEN=${max_model_len}
QUANTIZATION=${quantization}
ROPE_SCALING_JSON=${rope_scaling_json}
GPU_MEMORY_UTILIZATION=${gpu_memory_utilization}
ENFORCE_EAGER=${enforce_eager}
VLLM_EXTRA_ARGS=${vllm_extra_args}
VLLM_COMMAND=${vllm_command}
LANGUAGE_MODEL_ONLY=${language_model_only}
REASONING_PARSER=${reasoning_parser}
ACCELERATOR=${accelerator}
RUNTIME_PACK=${runtime_pack}
RUNTIME_PORT=${runtime_port}
AWS_REGION=${aws_region}
HF_HOME=/opt/emberlane/model-cache
TRANSFORMERS_CACHE=/opt/emberlane/model-cache
XDG_CACHE_HOME=/opt/emberlane/model-cache
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
ARTIFACT_BUCKET=${artifact_bucket}
ARTIFACT_PREFIX=${artifact_prefix}
S3_NEURON_ARTIFACTS_URI=${s3_neuron_artifacts_uri}
SYNC_ARTIFACTS_BACK=${sync_artifacts_back}
HF_TOKEN_SECRET_ARN=${hf_token_secret_arn}
HF_TOKEN_SSM_PARAMETER_NAME=${hf_token_ssm_parameter_name}
ENV
chmod 0600 /etc/emberlane/inf2.env

if command -v aws >/dev/null 2>&1; then
  if [[ -n "${hf_token_ssm_parameter_name}" ]]; then
    echo "[emberlane] loading HF token from SSM"
    HF_TOKEN_VALUE="$(aws ssm get-parameter --name "${hf_token_ssm_parameter_name}" --with-decryption --query Parameter.Value --output text --region "${aws_region}")"
    printf 'HF_TOKEN=%q\n' "$HF_TOKEN_VALUE" >>/etc/emberlane/inf2.env
  fi
fi

# 5. Runtime Launch Logic
if [[ "${accelerator}" == "cuda" ]]; then
    echo "[emberlane] Preparing CUDA vLLM service"
IMAGE="vllm/vllm-openai:latest"
GPU_FLAGS="--gpus all"
# Emberlane builds the command with safetensors prefetch on CUDA so the instance
# spends less time blocked on weight loads during startup.
CMD_ARGS="${vllm_command}"
    
    cat >/etc/systemd/system/emberlane-runtime.service <<UNIT
[Unit]
Description=Emberlane CUDA Runtime
After=docker.service
Wants=docker.service

[Service]
EnvironmentFile=/etc/emberlane/inf2.env
Restart=always
ExecStartPre=-/usr/bin/docker stop emberlane-vllm
ExecStartPre=-/usr/bin/docker rm emberlane-vllm
ExecStart=/usr/bin/docker run --rm --name emberlane-vllm \
  $GPU_FLAGS --shm-size=10.24gb \
  -v /opt/emberlane/model-cache:/opt/emberlane/model-cache \
  -p ${runtime_port}:8000 \
  -e HF_HOME=/opt/emberlane/model-cache \
  -e TRANSFORMERS_CACHE=/opt/emberlane/model-cache \
  -e XDG_CACHE_HOME=/opt/emberlane/model-cache \
  -e PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True \
  -e HF_TOKEN=\$${HF_TOKEN} \
  $IMAGE $CMD_ARGS
ExecStop=/usr/bin/docker stop emberlane-vllm

[Install]
WantedBy=multi-user.target
UNIT

elif [[ "${accelerator}" == "inf2" ]]; then
    echo "[emberlane] Preparing Inf2 Neuron vLLM service"
    # For Inf2, we need to enumerate devices
    NEURON_DEVICES=""
    for dev in /dev/neuron*; do
        NEURON_DEVICES="$NEURON_DEVICES --device $dev:$dev"
    done
    
    # Official AWS Neuron vLLM Image
    IMAGE="public.ecr.aws/neuron/pytorch-inference-vllm-neuronx:0.16.0-neuronx-py312-sdk2.29.1-ubuntu24.04"
    if ! python3 - <<'PY' >/dev/null 2>&1
import huggingface_hub
PY
    then
        python3 -m pip install --upgrade pip >/dev/null 2>&1
        python3 -m pip install huggingface_hub >/dev/null 2>&1
    fi
    MODEL_LOCAL_PATH="$(python3 - <<'PY'
import os
from huggingface_hub import snapshot_download

path = snapshot_download(
    repo_id="${model_id}",
    cache_dir=os.environ.get("HF_HOME", "/opt/emberlane/model-cache"),
    token=os.environ.get("HF_TOKEN") or None,
)
print(path)
PY
)"
    CMD_ARGS="$(printf '%s' "${vllm_command}" | sed "s|${model_id}|${MODEL_LOCAL_PATH}|")"

    cat >/etc/systemd/system/emberlane-runtime.service <<UNIT
[Unit]
Description=Emberlane Inf2 Runtime
After=docker.service
Wants=docker.service

[Service]
EnvironmentFile=/etc/emberlane/inf2.env
Restart=always
ExecStartPre=-/usr/bin/docker stop emberlane-vllm
ExecStartPre=-/usr/bin/docker rm emberlane-vllm
ExecStart=/usr/bin/docker run --rm --name emberlane-vllm \
  $NEURON_DEVICES \
  --shm-size=2g \
  -e VLLM_USE_V1=0 \
  -e VLLM_ATTENTION_BACKEND=NEURON \
  -p ${runtime_port}:8000 \
  -v /opt/emberlane/model-cache:/opt/emberlane/model-cache \
  -e HF_HOME=/opt/emberlane/model-cache \
  -e TRANSFORMERS_CACHE=/opt/emberlane/model-cache \
  -e XDG_CACHE_HOME=/opt/emberlane/model-cache \
  -e HF_TOKEN=\$${HF_TOKEN} \
  $IMAGE $CMD_ARGS
ExecStop=/usr/bin/docker stop emberlane-vllm

[Install]
WantedBy=multi-user.target
UNIT
fi

systemctl daemon-reload
systemctl enable --now emberlane-runtime.service

echo "[emberlane] Bootstrap complete."
