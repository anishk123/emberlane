#!/usr/bin/env bash
set -euo pipefail

# 1. Logging and basic setup
mkdir -p /etc/emberlane /opt/emberlane /opt/emberlane/model-cache /opt/emberlane/neuron-cache /var/log/emberlane
exec > >(tee -a /var/log/emberlane/bootstrap.log) 2>&1

echo "[emberlane] ========================================"
echo "[emberlane] Bootstrap started at $(date -u +%Y-%m-%dT%H:%M:%SZ)"

# 2. OS Detection and Lightweight Package Install
if [[ -f /etc/os-release ]]; then
    . /etc/os-release
    OS_ID=$ID
else
    OS_ID="unknown"
fi

echo "[emberlane] OS detected: $OS_ID ($${VERSION_ID:-unknown})"

case "$OS_ID" in
    ubuntu)
        PM="apt-get"
        export DEBIAN_FRONTEND=noninteractive
        apt-get update -y
        deps=(curl jq unzip snapd python3-pip)
        if ! command -v docker >/dev/null 2>&1; then
            deps+=(docker.io)
        fi
        apt-get install -y "$${deps[@]}" || true # Don't fail if some deps (like docker) are held/pre-installed
        systemctl enable --now docker
        ;;
    amzn|al2023)
        PM="dnf"
        deps=(curl jq unzip python3-pip)
        if ! command -v docker >/dev/null 2>&1; then
            deps+=(docker)
        fi
        dnf install -y "$${deps[@]}" 
        systemctl enable --now docker
        ;;
    *)
        echo "[emberlane] WARNING: Unsupported OS $OS_ID. Attempting to proceed with basic tools."
        ;;
esac

ensure_ssm_agent() {
    case "$OS_ID" in
        ubuntu)
            if ! snap list amazon-ssm-agent >/dev/null 2>&1; then
                echo "[emberlane] installing SSM agent via snap"
                snap install amazon-ssm-agent --classic || true
            fi
            systemctl enable --now snap.amazon-ssm-agent.amazon-ssm-agent.service >/dev/null 2>&1 || true
            snap start amazon-ssm-agent >/dev/null 2>&1 || true
            ;;
        amzn|al2023)
            if ! rpm -q amazon-ssm-agent >/dev/null 2>&1; then
                echo "[emberlane] installing SSM agent via rpm"
                dnf install -y https://s3.amazonaws.com/ec2-downloads-windows/SSMAgent/latest/linux_amd64/amazon-ssm-agent.rpm \
                  || yum install -y https://s3.amazonaws.com/ec2-downloads-windows/SSMAgent/latest/linux_amd64/amazon-ssm-agent.rpm \
                  || true
            fi
            systemctl enable --now amazon-ssm-agent >/dev/null 2>&1 || true
            ;;
    esac
}

ensure_ssm_agent

# 3. Preflight Diagnostic Block
echo "[emberlane] --- PREFLIGHT LOGS ---"
IMDS_TOKEN="$(curl -s -X PUT http://169.254.169.254/latest/api/token -H 'X-aws-ec2-metadata-token-ttl-seconds: 21600' || true)"
metadata() {
    local path="$1"
    if [[ -n "$${IMDS_TOKEN}" ]]; then
        curl -s -H "X-aws-ec2-metadata-token: $${IMDS_TOKEN}" "http://169.254.169.254/latest/meta-data/$${path}" || true
    else
        curl -s "http://169.254.169.254/latest/meta-data/$${path}" || true
    fi
}
echo "AMI_ID: $(metadata ami-id)"
echo "INSTANCE_TYPE: $(metadata instance-type)"
echo "UNAME: $(uname -a)"
echo "OS_RELEASE: $(cat /etc/os-release | grep PRETTY_NAME)"
docker --version || echo "docker not found"

if [[ "${accelerator}" == "cuda" ]]; then
    nvidia-smi || { echo "ERROR: nvidia-smi failed on CUDA instance"; exit 1; }
elif [[ "${accelerator}" == "inf2" ]]; then
    if [[ ! -e /dev/neuron0 ]]; then
        echo "ERROR: /dev/neuron0 not found on Inf2 instance. Use an Inf2 instance with Neuron drivers/runtime installed."
        exit 1
    elif command -v neuron-ls >/dev/null 2>&1; then
        neuron-ls
    else
        echo "WARNING: neuron-ls not found on host; continuing because the Neuron vLLM container can still use /dev/neuron* devices."
    fi
fi
echo "[emberlane] --- PREFLIGHT COMPLETE ---"

# 4. Environment and Secrets
echo "[emberlane] writing runtime environment"
cat >/etc/emberlane/inf2.env <<'ENV'
MODEL_PROFILE=${model_profile}
MODEL_ID=${model_id}
MAX_MODEL_LEN=${max_model_len}
QUANTIZATION=${quantization}
ROPE_SCALING_JSON=${rope_scaling_json}
GPU_MEMORY_UTILIZATION=${gpu_memory_utilization}
ENFORCE_EAGER=${enforce_eager}
LANGUAGE_MODEL_ONLY=${language_model_only}
REASONING_PARSER=${reasoning_parser}
ACCELERATOR=${accelerator}
RUNTIME_PACK=${runtime_pack}
RUNTIME_PORT=${runtime_port}
AWS_REGION=${aws_region}
HF_HOME=/opt/emberlane/model-cache
TRANSFORMERS_CACHE=/opt/emberlane/model-cache
XDG_CACHE_HOME=/opt/emberlane/model-cache
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
ARTIFACT_BUCKET=${artifact_bucket}
ARTIFACT_PREFIX=${artifact_prefix}
S3_NEURON_ARTIFACTS_URI=${s3_neuron_artifacts_uri}
SYNC_ARTIFACTS_BACK=${sync_artifacts_back}
HF_TOKEN_SECRET_ARN=${hf_token_secret_arn}
HF_TOKEN_SSM_PARAMETER_NAME=${hf_token_ssm_parameter_name}
ENV
chmod 0600 /etc/emberlane/inf2.env

cat >/etc/emberlane/vllm-command <<'EOF'
${vllm_command}
EOF

if command -v aws >/dev/null 2>&1; then
  if [[ -n "${hf_token_ssm_parameter_name}" ]]; then
    echo "[emberlane] loading HF token from SSM"
    HF_TOKEN_VALUE="$(aws ssm get-parameter --name "${hf_token_ssm_parameter_name}" --with-decryption --query Parameter.Value --output text --region "${aws_region}")"
    printf 'HF_TOKEN=%q\n' "$HF_TOKEN_VALUE" >>/etc/emberlane/inf2.env
  fi
fi

if [[ -n "${runtime_pack_s3_uri}" ]]; then
    echo "[emberlane] staging runtime pack from ${runtime_pack_s3_uri}"
    rm -rf /opt/emberlane/inf2-runtime
    mkdir -p /opt/emberlane/inf2-runtime
    TMP_RUNTIME_PACK="/tmp/emberlane-inf2-runtime-pack.zip"
    aws s3 cp "${runtime_pack_s3_uri}" "$${TMP_RUNTIME_PACK}" --region "${aws_region}"
    unzip -o "$${TMP_RUNTIME_PACK}" -d /opt/emberlane/inf2-runtime
    chmod +x /opt/emberlane/inf2-runtime/bootstrap.sh /opt/emberlane/inf2-runtime/start-server.sh /opt/emberlane/inf2-runtime/scripts/*.sh /opt/emberlane/inf2-runtime/scripts/*.py /opt/emberlane/inf2-runtime/server/*.py || true
fi

# 5. Runtime Launch Logic
if [[ "${accelerator}" == "cuda" ]]; then
    echo "[emberlane] Preparing CUDA vLLM service"
IMAGE="vllm/vllm-openai:latest"
GPU_FLAGS="--gpus all"
# Emberlane builds the command with safetensors prefetch on CUDA so the instance
# spends less time blocked on weight loads during startup.
    # docker run --rm --name emberlane-vllm
    cat >/usr/local/bin/emberlane-launch-runtime.sh <<UNIT
#!/usr/bin/env bash
set -euo pipefail

/usr/bin/docker stop emberlane-vllm >/dev/null 2>&1 || true
/usr/bin/docker rm emberlane-vllm >/dev/null 2>&1 || true

exec python3 - <<'PY'
import os
import shlex
import sys

os.environ["VLLM_TARGET_DEVICE"] = "neuron"
flags = os.environ.get("NEURON_CC_FLAGS", "")
if "--retry_failed_compilation" not in flags.split():
    os.environ["NEURON_CC_FLAGS"] = (flags + " --retry_failed_compilation").strip()

with open("/etc/emberlane/vllm-command", "r", encoding="utf-8") as fh:
    raw_command = fh.read().strip()

if not raw_command:
    sys.stderr.write("Emberlane startup error: /etc/emberlane/vllm-command is empty. Re-run deploy so Terraform renders vllm_command.\n")
    sys.exit(64)

vllm_args = shlex.split(raw_command)
if len(vllm_args) < 2 or vllm_args[0] != "serve" or not vllm_args[1].strip():
    sys.stderr.write(f"Emberlane startup error: invalid vLLM command: {raw_command!r}\n")
    sys.exit(64)

cmd = [
    "/usr/bin/docker",
    "run",
    "--rm",
    "--name",
    "emberlane-vllm",
    "--entrypoint",
    "vllm",
    "--gpus",
    "all",
    "--shm-size=10.24gb",
    "-v",
    "/opt/emberlane/model-cache:/opt/emberlane/model-cache",
    "-p",
    "${runtime_port}:8000",
    "-e",
    "HF_HOME=/opt/emberlane/model-cache",
    "-e",
    "TRANSFORMERS_CACHE=/opt/emberlane/model-cache",
    "-e",
    "XDG_CACHE_HOME=/opt/emberlane/model-cache",
    "-e",
    "PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True",
    "-e",
    f"HF_TOKEN={os.environ.get('HF_TOKEN', '')}",
    "vllm/vllm-openai:latest",
]
cmd.extend(vllm_args)

os.execv(cmd[0], cmd)
PY
UNIT
    chmod +x /usr/local/bin/emberlane-launch-runtime.sh

    cat >/etc/systemd/system/emberlane-runtime.service <<UNIT
[Unit]
Description=Emberlane CUDA Runtime
After=docker.service
Wants=docker.service

[Service]
EnvironmentFile=/etc/emberlane/inf2.env
Restart=always
ExecStart=/usr/local/bin/emberlane-launch-runtime.sh
ExecStop=/usr/bin/docker stop emberlane-vllm

[Install]
WantedBy=multi-user.target
UNIT

elif [[ "${accelerator}" == "inf2" ]]; then
    echo "[emberlane] Preparing Inf2 Neuron vLLM service"
    # For Inf2, we need to enumerate devices
    NEURON_DEVICES=""
    for dev in /dev/neuron*; do
        NEURON_DEVICES="$NEURON_DEVICES --device $dev:$dev"
    done
    
    # Official AWS Neuron vLLM Image
    IMAGE="public.ecr.aws/neuron/pytorch-inference-vllm-neuronx:0.16.0-neuronx-py312-sdk2.29.1-ubuntu24.04"
    INF2_VENV="/opt/emberlane/inf2-venv"
    if [[ ! -x "$${INF2_VENV}/bin/python" ]]; then
        if ! python3 -m venv "$${INF2_VENV}"; then
            if command -v apt-get >/dev/null 2>&1; then
                export DEBIAN_FRONTEND=noninteractive
                apt-get update -y
                apt-get install -y python3-venv
                python3 -m venv "$${INF2_VENV}"
            else
                echo "ERROR: python3 -m venv failed and apt-get is unavailable" >&2
                exit 1
            fi
        fi
    fi
    INF2_PYTHON="$${INF2_VENV}/bin/python"
    if ! "$${INF2_PYTHON}" - <<'PY' >/dev/null 2>&1
import importlib.util
raise SystemExit(0 if importlib.util.find_spec("huggingface_hub") else 1)
PY
    then
        "$${INF2_PYTHON}" -m pip install --quiet --upgrade "huggingface_hub>=0.23.0"
    fi
    MODEL_LOCAL_PATH="$($${INF2_PYTHON} - <<'PY'
import os
from huggingface_hub import snapshot_download

path = snapshot_download(
    repo_id="${model_id}",
    cache_dir=os.environ.get("HF_HOME", "/opt/emberlane/model-cache"),
    token=os.environ.get("HF_TOKEN") or None,
)
print(path)
PY
)"
    CMD_ARGS="$(printf '%s' "${vllm_command}" | sed "s|${model_id}|$${MODEL_LOCAL_PATH}|")"
    cat >/etc/emberlane/vllm-command <<EOF
$${CMD_ARGS}
EOF

    # docker run --rm --name emberlane-vllm
    cat >/usr/local/bin/emberlane-launch-runtime.sh <<UNIT
#!/usr/bin/env bash
set -euo pipefail

/usr/bin/docker stop emberlane-vllm >/dev/null 2>&1 || true
/usr/bin/docker rm emberlane-vllm >/dev/null 2>&1 || true

exec python3 - <<'PY'
import os
import shlex
import sys

with open("/etc/emberlane/vllm-command", "r", encoding="utf-8") as fh:
    raw_command = fh.read().strip()

if not raw_command:
    sys.stderr.write("Emberlane startup error: /etc/emberlane/vllm-command is empty. Re-run deploy so Terraform renders vllm_command.\n")
    sys.exit(64)

vllm_args = shlex.split(raw_command)
if len(vllm_args) < 2 or vllm_args[0] != "serve" or not vllm_args[1].strip():
    sys.stderr.write(f"Emberlane startup error: invalid vLLM command: {raw_command!r}\n")
    sys.exit(64)

cmd = [
    "/usr/bin/docker",
    "run",
    "--rm",
    "--name",
    "emberlane-vllm",
    "--entrypoint",
    "vllm",
]
cmd.extend(shlex.split("$${NEURON_DEVICES}"))
cmd.extend([
    "--shm-size=2g",
    "-e",
    "VLLM_USE_V1=0",
    "-e",
    "VLLM_TARGET_DEVICE=neuron",
    "-e",
    "VLLM_ATTENTION_BACKEND=NEURON",
    "-p",
    "${runtime_port}:8000",
    "-v",
    "/opt/emberlane/model-cache:/opt/emberlane/model-cache",
    "-e",
    "HF_HOME=/opt/emberlane/model-cache",
    "-e",
    "TRANSFORMERS_CACHE=/opt/emberlane/model-cache",
    "-e",
    "XDG_CACHE_HOME=/opt/emberlane/model-cache",
    "-e",
    f"HF_TOKEN={os.environ.get('HF_TOKEN', '')}",
    "public.ecr.aws/neuron/pytorch-inference-vllm-neuronx:0.16.0-neuronx-py312-sdk2.29.1-ubuntu24.04",
])
cmd.extend(vllm_args)

os.execv(cmd[0], cmd)
PY
UNIT
    chmod +x /usr/local/bin/emberlane-launch-runtime.sh

    cat >/etc/systemd/system/emberlane-runtime.service <<UNIT
[Unit]
Description=Emberlane Inf2 Runtime
After=docker.service
Wants=docker.service

[Service]
EnvironmentFile=/etc/emberlane/inf2.env
Restart=always
ExecStart=/usr/local/bin/emberlane-launch-runtime.sh
ExecStop=/usr/bin/docker stop emberlane-vllm

[Install]
WantedBy=multi-user.target
UNIT
fi

systemctl daemon-reload
systemctl enable --now emberlane-runtime.service

echo "[emberlane] Bootstrap complete."
